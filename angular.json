{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "",
  "projects": {
    "morningharwood": {
      "root": "apps/morningharwood",
      "sourceRoot": "apps/morningharwood/src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/apps/morningharwood",
            "index": "apps/morningharwood/src/index.html",
            "main": "apps/morningharwood/src/main.ts",
            "polyfills": "apps/morningharwood/src/polyfills.ts",
            "tsConfig": "apps/morningharwood/tsconfig.app.json",
            "assets": [
              "apps/morningharwood/src/favicon.ico",
              "apps/morningharwood/src/assets",
              "apps/morningharwood/src/manifest.json"
            ],
            "styles": [
              "apps/morningharwood/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/morningharwood/src/environments/environment.ts",
                  "with": "apps/morningharwood/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "serviceWorker": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "morningharwood:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "morningharwood:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "morningharwood:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/morningharwood/src/test.ts",
            "polyfills": "apps/morningharwood/src/polyfills.ts",
            "tsConfig": "apps/morningharwood/tsconfig.spec.json",
            "karmaConfig": "apps/morningharwood/karma.conf.js",
            "styles": [
              "apps/morningharwood/src/styles.css"
            ],
            "scripts": [],
            "assets": [
              "apps/morningharwood/src/favicon.ico",
              "apps/morningharwood/src/assets",
              "apps/morningharwood/src/manifest.json"
            ]
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "apps/morningharwood/tsconfig.app.json",
              "apps/morningharwood/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        },
        "server": {
          "builder": "@angular-devkit/build-angular:server",
          "options": {
            "outputPath": "dist/apps/morningharwood-server",
            "main": "apps/morningharwood/src/main.server.ts",
            "tsConfig": "apps/morningharwood/tsconfig.server.json"
          }
        },
        "app-shell": {
          "builder": "@angular-devkit/build-angular:app-shell",
          "options": {
            "browserTarget": "morningharwood:build",
            "serverTarget": "morningharwood:server",
            "route": "app-shell-path"
          }
        }
      }
    },
    "morningharwood-e2e": {
      "root": "apps/morningharwood-e2e",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "apps/morningharwood-e2e/protractor.conf.js",
            "devServerTarget": "morningharwood:serve"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": "apps/morningharwood-e2e/tsconfig.e2e.json",
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "firebase": {
      "root": "libs/firebase",
      "sourceRoot": "libs/firebase/src",
      "projectType": "library",
      "prefix": "morningharwood",
      "architect": {
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "libs/firebase/src/test.ts",
            "tsConfig": "libs/firebase/tsconfig.spec.json",
            "karmaConfig": "libs/firebase/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "libs/firebase/tsconfig.lib.json",
              "libs/firebase/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "themes": {
      "root": "libs/themes",
      "sourceRoot": "libs/themes/src",
      "projectType": "library",
      "prefix": "morningharwood",
      "architect": {
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "libs/themes/src/test.ts",
            "tsConfig": "libs/themes/tsconfig.spec.json",
            "karmaConfig": "libs/themes/karma.conf.js",
            "assets": [
              "apps/morningharwood/src/assets"
            ]
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "libs/themes/tsconfig.lib.json",
              "libs/themes/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "portfolio": {
      "root": "libs/portfolio",
      "sourceRoot": "libs/portfolio/src",
      "projectType": "library",
      "prefix": "morningharwood",
      "architect": {
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "libs/portfolio/src/test.ts",
            "tsConfig": "libs/portfolio/tsconfig.spec.json",
            "karmaConfig": "libs/portfolio/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "libs/portfolio/tsconfig.lib.json",
              "libs/portfolio/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "author": {
      "root": "apps/author/",
      "sourceRoot": "apps/author/src",
      "projectType": "application",
      "prefix": "morningharwood",
      "schematics": {
        "@schematics/angular:component": {
          "styleext": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/apps/author",
            "index": "apps/author/src/index.html",
            "main": "apps/author/src/main.ts",
            "polyfills": "apps/author/src/polyfills.ts",
            "tsConfig": "apps/author/tsconfig.app.json",
            "assets": [
              "apps/author/src/favicon.ico",
              "apps/author/src/assets"
            ],
            "styles": [
              "apps/author/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/author/src/environments/environment.ts",
                  "with": "apps/author/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "author:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "author:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "author:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/author/src/test.ts",
            "polyfills": "apps/author/src/polyfills.ts",
            "tsConfig": "apps/author/tsconfig.spec.json",
            "karmaConfig": "apps/author/karma.conf.js",
            "styles": [
              "apps/author/src/styles.scss"
            ],
            "scripts": [],
            "assets": [
              "apps/author/src/favicon.ico",
              "apps/author/src/assets"
            ]
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "apps/author/tsconfig.app.json",
              "apps/author/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "author-e2e": {
      "root": "apps/author-e2e/",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "apps/author-e2e/protractor.conf.js",
            "devServerTarget": "author:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "author:serve:production"
            }
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": "apps/author-e2e/tsconfig.e2e.json",
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    }
  },
  "defaultProject": "morningharwood",
  "cli": {
    "defaultCollection": "@nrwl/schematics"
  }
}
